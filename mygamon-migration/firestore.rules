rules_version = '2';

// ============================================================
// MyGameON Hub — Firestore Security Rules
// Phase 0: Foundation
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================================
    // HELPER FUNCTIONS
    // ========================================================
    
    function isAdmin() {
      return request.auth != null 
             && request.auth.token.admin == true;
    }
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // ========================================================
    // PUBLIC: games/
    // ========================================================
    // Public bisa baca game yang available & non-problematic
    // Admin bisa baca/tulis semua game
    
    match /games/{gameId} {
      allow read: if isAdmin() || (
        resource.data.isProblematic == false &&
        resource.data.availabilityStatus != 'unavailable'
      );
      
      allow create, update, delete: if isAdmin();
    }
    
    // ========================================================
    // ADMIN-ONLY: gamesPrivate/
    // ========================================================
    // Hanya admin yang bisa akses, tidak bocor ke public
    
    match /gamesPrivate/{gameId} {
      allow read, write: if isAdmin();
    }
    
    // ========================================================
    // METADATA: genres, tags, playModes, platforms
    // ========================================================
    // Public bisa baca (untuk display label di frontend)
    // Hanya admin yang bisa write
    
    match /metadata/{type}/entries/{entryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ========================================================
    // EXISTING COLLECTIONS (preserve current rules)
    // ========================================================
    // Sesuaikan dengan existing rules kamu untuk:
    // - requests/
    // - users/ (kalau ada)
    // - admin/ (kalau ada)
    
    // Contoh untuk requests/ — sesuaikan dengan setup existing
    match /requests/{requestId} {
      allow read: if isAdmin();
      allow create: if true; // anonymous bisa submit request
      allow update, delete: if isAdmin();
    }
    
    // ========================================================
    // FALLBACK: deny by default
    // ========================================================
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
