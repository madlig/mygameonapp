rules_version = '2';

// ============================================================
// MyGameON Hub — Firestore Security Rules
// 
// Updated: 26 April 2026 — Phase 0 (Detail Page Foundation)
// 
// Changes from previous version:
// - Added: gamesPrivate/ (admin-only, separated from games/)
// - Added: metadata/{type}/entries/{id} (public read, admin write)
// - Updated: games/ read rule (filter isProblematic + availabilityStatus)
// - Removed: genres/ (migrated to metadata/genres/entries/)
// - Cleaned: isAdmin() now uses single 'role' custom claim
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================
    // HELPER FUNCTIONS
    // ========================================================

    function isSignedIn() {
      return request.auth != null;
    }

    // Single source of truth: role-based check
    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isMember() {
      return isSignedIn() && request.auth.token.role == 'member';
    }

    // For public Detail Page access — filter out problematic/unavailable games
    function isPubliclyVisibleGame() {
      return resource.data.isProblematic == false 
             && resource.data.availabilityStatus != 'unavailable';
    }

    function isValidTrackingCode() {
      return request.resource.data.trackingCode is string &&
        request.resource.data.trackingCode.matches('^RQ-[A-Z0-9]{6}$');
    }

    function isPublicRequestCreate() {
      return request.resource.data.keys().hasOnly([
          'title',
          'title_lower',
          'platform',
          'notes',
          'shopeeUsername',
          'contactWhatsApp',
          'status',
          'trackingCode',
          'votes',
          'createdAt',
          'updatedAt'
      ]) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() >= 3 &&
        request.resource.data.title.size() <= 80 &&
        request.resource.data.title_lower is string &&
        request.resource.data.platform == 'PC' &&
        request.resource.data.notes is string &&
        
        // Validasi Shopee Username
        request.resource.data.shopeeUsername is string &&
        request.resource.data.shopeeUsername.size() > 0 &&
        request.resource.data.shopeeUsername.size() <= 30 &&
        
        // Validasi WhatsApp
        request.resource.data.contactWhatsApp is string &&
        request.resource.data.contactWhatsApp.size() >= 9 &&
        request.resource.data.contactWhatsApp.size() <= 20 &&
        request.resource.data.contactWhatsApp.matches('^[0-9+\\-\\s]+$') &&
        
        request.resource.data.status == 'pending' &&
        request.resource.data.votes == 1 &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.updatedAt is timestamp &&
        isValidTrackingCode();
    }

    // Public update for vote increment only
    function isPublicVoteUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes', 'updatedAt']) &&
        request.resource.data.votes is number &&
        resource.data.votes is number &&
        request.resource.data.votes == resource.data.votes + 1 &&
        request.resource.data.updatedAt is timestamp;
    }

    // ========================================================
    // PUBLIC COLLECTIONS — games & requests
    // ========================================================

    // Games:
    // - Public: read kalau not problematic and available
    // - Admin: read all (preview), write all
    match /games/{gameId} {
      allow read: if isAdmin() || isPubliclyVisibleGame();
      allow write: if isAdmin();
    }

    // Requests: existing logic preserved
    // - create: public submission allowed (tight validation)
    // - read: public can check duplicates
    // - update: admin full / public vote increment only
    // - delete: admin only
    match /requests/{reqId} {
      allow create: if isAdmin() || isPublicRequestCreate();
      allow read: if true;
      allow update: if isAdmin() || isPublicVoteUpdate();
      allow delete: if isAdmin();
    }

    // ========================================================
    // ADMIN-ONLY: gamesPrivate (NEW — Phase 0)
    // ========================================================

    match /gamesPrivate/{gameId} {
      allow read, write: if isAdmin();
    }

    // ========================================================
    // METADATA: genres, tags, playModes, platforms (NEW — Phase 0)
    // ========================================================
    // Public can read for displaying labels in UI
    // Only admin can write to maintain consistency

    match /metadata/{type}/entries/{entryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ========================================================
    // CONTENT: tutorials, downloads, prerequisites, blogs
    // ========================================================

    match /tutorials/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /downloads/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /prerequisites/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /blogs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Winning Product: single-doc spotlight on landing page
    match /winningProduct/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ========================================================
    // FAQ & USER QUESTIONS
    // ========================================================

    // FAQs: public can read active items, admin manages all
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User questions: public can submit, admin manages
    match /userQuestions/{qId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ========================================================
    // ADMIN / OPERATIONAL COLLECTIONS (preserved from existing)
    // ========================================================

    // NOTE: genres/ removed — migrated to metadata/genres/entries/

    match /emailLocations/{locId} {
      allow read, write: if isAdmin();
    }

    match /projects/{projectId} {
      allow read, write: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read, write: if isAdmin();
    }

    // Operational tracking — current names
    match /adminShifts/{shiftId} {
      allow read, write: if isAdmin();
    }

    match /dailyRevenues/{revId} {
      allow read, write: if isAdmin();
    }

    match /shopeeAnalytics/{docId} {
      allow read, write: if isAdmin();
    }

    match /operational_daily_recap/{docId} {
      allow read, write: if isAdmin();
    }

    // Legacy names — preserved for backward compatibility
    match /shifts/{shiftId} {
      allow read, write: if isAdmin();
    }

    match /daily_revenues/{dateId} {
      allow read, write: if isAdmin();
    }

    // ========================================================
    // CONFIG (NEW — for future Google login flow)
    // ========================================================
    // Stores admin email whitelist — referenced by auth Cloud Function

    match /config/{configId} {
      allow read, write: if isAdmin();
    }

    // ========================================================
    // USER-SCOPED DATA
    // ========================================================

    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // User activity log (for future audit trail)
    match /userActivityLog/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions can write
    }

    // ========================================================
    // DEFAULT DENY
    // ========================================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
